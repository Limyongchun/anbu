      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://anbu-family.replit.app/api",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "589055853445-2p9cqa4rnoc3n5bv90t3r91gjad2jjs5.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "589055853445-m6utvvh4duvmvfd1la37n2v9u7inacku.apps.googleusercontent.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://anbu-family.replit.app/api",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "589055853445-2p9cqa4rnoc3n5bv90t3r91gjad2jjs5.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "589055853445-m6utvvh4duvmvfd1la37n2v9u7inacku.apps.googleusercontent.com"
      }
    }
  },
  "submit": {
    "production": {
